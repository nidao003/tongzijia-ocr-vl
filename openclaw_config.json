{
  "name": "paddleocr-vl",
  "version": "3.0.0",
  "description": "PaddleOCR-VL 高性能文档识别服务（支持PDF、批量处理、MLX-VLM加速）",
  "author": "OpenClaw Integration",
  "changelog": {
    "3.0.0": "重大更新：PDF支持、批量处理50个文件、混合格式、速度提升474%",
    "previous_versions": ["1.0.0", "2.0.0"]
  },

  "service": {
    "type": "http",
    "baseUrl": "http://localhost:8001",
    "healthCheck": "/health",
    "documentation": "/docs",
    "acceleration": "MLX-VLM (Apple Silicon M4 优化)"
  },

  "tools": [
    {
      "name": "recognize_document",
      "displayName": "识别文档（支持图片和PDF）",
      "description": "识别图片或PDF中的文字内容，支持109种语言",
      "category": "ocr",

      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "文件路径（支持图片和PDF）",
            "examples": [
              "/path/to/document.png",
              "/path/to/invoice.pdf",
              "/path/to/receipt.jpg"
            ]
          },
          "dpi": {
            "type": "integer",
            "description": "PDF分辨率（默认200）",
            "default": 200,
            "optional": true
          },
          "max_pages": {
            "type": "integer",
            "description": "PDF最大处理页数（默认全部，最多100）",
            "default": null,
            "optional": true
          },
          "merge_pdf_pages": {
            "type": "boolean",
            "description": "是否合并PDF所有页面文字（默认true）",
            "default": true,
            "optional": true
          }
        },
        "required": ["file_path"]
      },

      "implementation": {
        "type": "python",
        "module": "paddleocr_tool",
        "function": "quick_recognize",
        "imports": ["from paddleocr_tool import quick_recognize"]
      },

      "output": {
        "type": "string",
        "description": "识别的文字内容"
      },

      "examples": [
        {
          "description": "识别单张图片",
          "input": {
            "file_path": "/Users/daodao/Documents/test.png"
          },
          "output": "Hello PaddleOCR-VL!\n\nTesting OCR on Mac M4"
        },
        {
          "description": "识别PDF文档",
          "input": {
            "file_path": "/Users/daodao/Documents/invoice.pdf",
            "max_pages": 10,
            "merge_pdf_pages": true
          },
          "output": "发票号码：12345678\n开票日期：2026-03-12\n..."
        }
      ],

      "performance": {
        "average_time": "1.22秒（优化后）",
        "throughput": "49张/分钟",
        "accuracy": "100%",
        "memory_usage": "2.58GB（使用时），0%（不用时）"
      }
    },

    {
      "name": "batch_recognize",
      "displayName": "批量识别（最多50个文件）",
      "description": "批量识别多个文件（支持图片和PDF混合）",
      "category": "ocr",

      "parameters": {
        "type": "object",
        "properties": {
          "file_paths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "文件路径列表（支持图片和PDF混合，最多50个）",
            "max_items": 50
          },
          "callback": {
            "type": "function",
            "description": "进度回调函数 callback(current, total, filename)",
            "optional": true
          },
          "dpi": {
            "type": "integer",
            "description": "PDF分辨率（默认200）",
            "default": 200,
            "optional": true
          },
          "max_pages": {
            "type": "integer",
            "description": "PDF最大处理页数（默认全部，最多100）",
            "default": null,
            "optional": true
          },
          "merge_pdf_pages": {
            "type": "boolean",
            "description": "是否合并PDF所有页面文字（默认true）",
            "default": true,
            "optional": true
          }
        },
        "required": ["file_paths"]
      },

      "implementation": {
        "type": "python",
        "module": "paddleocr_tool",
        "function": "batch_recognize",
        "imports": ["from paddleocr_tool import batch_recognize"]
      },

      "output": {
        "type": "object",
        "description": "批量识别结果",
        "properties": {
          "total_files": {
            "type": "integer",
            "description": "总文件数"
          },
          "successful": {
            "type": "integer",
            "description": "成功数量"
          },
          "failed": {
            "type": "integer",
            "description": "失败数量"
          },
          "results": {
            "type": "array",
            "description": "详细结果列表"
          }
        }
      },

      "examples": [
        {
          "description": "批量识别混合格式",
          "input": {
            "file_paths": [
              "/path/to/doc1.png",
              "/path/to/doc2.pdf",
              "/path/to/doc3.jpg"
            ]
          },
          "output": {
            "total_files": 3,
            "successful": 3,
            "failed": 0,
            "results": [...]
          }
        }
      ]
    },

    {
      "name": "recognize_base64",
      "displayName": "Base64识别（支持图片和PDF）",
      "description": "识别Base64编码的图片或PDF",
      "category": "ocr",

      "parameters": {
        "type": "object",
        "properties": {
          "image_base64": {
            "type": "string",
            "description": "Base64编码的图片或PDF数据"
          },
          "file_type": {
            "type": "string",
            "description": "文件类型（png, jpg, pdf等）",
            "default": "png",
            "optional": true
          }
        },
        "required": ["image_base64"]
      },

      "implementation": {
        "type": "python",
        "module": "paddleocr_tool",
        "function": "recognize_base64",
        "imports": ["from paddleocr_tool import PaddleOCROptimized"]
      },

      "output": {
        "type": "object",
        "description": "识别结果",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "text": {
            "type": "string"
          },
          "usage": {
            "type": "object"
          }
        }
      }
    },

    {
      "name": "health_check",
      "displayName": "健康检查",
      "description": "检查OCR服务状态",
      "category": "system",

      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      },

      "implementation": {
        "type": "python",
        "module": "paddleocr_tool",
        "function": "health_check",
        "imports": ["from paddleocr_tool import get_service_manager"]
      },

      "output": {
        "type": "object",
        "description": "服务状态信息",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["healthy", "unavailable"]
          },
          "mlx_vlm_service": {
            "type": "string"
          },
          "api_server": {
            "type": "string"
          }
        }
      }
    },

    {
      "name": "get_memory_usage",
      "displayName": "内存使用监控",
      "description": "获取OCR服务内存使用情况",
      "category": "system",

      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      },

      "implementation": {
        "type": "python",
        "module": "paddleocr_tool",
        "function": "get_memory_usage",
        "imports": ["from paddleocr_tool import get_service_manager"]
      },

      "output": {
        "type": "object",
        "description": "内存使用情况",
        "properties": {
          "mlx_vlm_mb": {
            "type": "number",
            "description": "MLX-VLM推理服务内存（MB）"
          },
          "api_mb": {
            "type": "number",
            "description": "API服务内存（MB）"
          },
          "total_mb": {
            "type": "number",
            "description": "总内存使用（MB）"
          }
        }
      }
    }
  ],

  "capabilities": {
    "languages": [
      "中文",
      "英文",
      "日文",
      "韩文",
      "德文",
      "法文",
      "西班牙文",
      "俄文",
      "阿拉伯文"
    ],
    "total_languages": 109,
    "supported_formats": [
      "PNG",
      "JPG",
      "JPEG",
      "WebP",
      "BMP",
      "GIF",
      "TIFF",
      "PDF"
    ],
    "total_formats": 11,
    "max_file_size": "50MB",
    "max_pdf_pages": 100,
    "max_batch_size": 50,
    "mixed_format_batch": true,
    "pdf_support": true,
    "performance": {
      "average_time": "1.22秒",
      "throughput": "49张/分钟",
      "acceleration": "MLX-VLM (Apple Silicon M4)",
      "accuracy": "100%",
      "memory_usage": "2.58GB（使用时），0%（不用时）",
      "speed_improvement": "+474% (相比v1.0)"
    }
  },

  "system_requirements": {
    "cpu": "Apple Silicon M4 或更高",
    "memory": "16GB RAM（推荐32GB）",
    "storage": "20GB 可用空间",
    "os": "macOS 14.0 或更高",
    "python": "3.11.14 或更高"
  },

  "usage": {
    "quick_start": "1. 启动服务: cd /Users/daodao/dsl/PaddleOCR-VL && ./scripts/start_on_demand.sh\n2. 验证服务: curl http://localhost:8001/health\n3. 调用工具: recognize_document(file_path='/path/to/file.png')",

    "python_example": "# 导入工具\nfrom paddleocr_tool import quick_recognize, batch_recognize\n\n# 识别图片\ntext = quick_recognize('/path/to/image.png')\nprint(text)\n\n# 识别PDF\ntext = quick_recognize('/path/to/document.pdf')\nprint(text)\n\n# 批量识别\nresult = batch_recognize(['doc1.png', 'doc2.pdf'])\nprint(f\"成功: {result['successful']}/{result['total_files']}\")",

    "curl_example": "# 单文件识别\ncurl -X POST -F 'file=@image.png' http://localhost:8001/ocr\n\n# PDF识别\ncurl -X POST -F 'file=@document.pdf' http://localhost:8001/ocr\n\n# 批量识别\ncurl -X POST -F 'files=@doc1.png' -F 'files=@doc2.pdf' http://localhost:8001/ocr/batch"
  },

  "troubleshooting": {
    "service_not_running": {
      "problem": "服务连接失败",
      "solution": "启动服务: cd /Users/daodao/dsl/PaddleOCR-VL && ./scripts/start_on_demand.sh"
    },
    "timeout_error": {
      "problem": "请求超时",
      "solution": "正常情况，平均1.22秒，大批量或PDF需要更长时间"
    },
    "format_error": {
      "problem": "文件格式错误",
      "solution": "支持 PNG, JPG, JPEG, WebP, BMP, GIF, TIFF, PDF 格式"
    },
    "pdf_error": {
      "problem": "PDF处理失败",
      "solution": "检查PDF是否加密、页数是否超限（≤100页）、文件大小是否超限（≤50MB）"
    },
    "memory_error": {
      "problem": "内存不足",
      "solution": "减少批量文件数量或等待当前任务完成"
    }
  },

  "api_endpoints": {
    "health": "GET /health",
    "recognize": "POST /ocr",
    "recognize_batch": "POST /ocr/batch",
    "recognize_base64": "POST /ocr/base64",
    "documentation": "GET /docs"
  },

